# Gemini API Key for Plant Analysis
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend Email Configuration (for Nodemailer)
# Use your Gmail address and an App Password (not your regular password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# MongoDB Connection String (Atlas for production, local for development)
MONGO_URI=mongodb://127.0.0.1:27017/pritamoria_db

# Email Delegation Configuration (used in Render backend to call Vercel email endpoint)
# VERCEL_EMAIL_API_URL=https://your-vercel-domain.vercel.app/api/send-email
# EMAIL_API_SECRET=your_secure_shared_secret_here

